# =====================================================================
# SF登録早期化プロジェクト — .gitignore
#
# このファイルが守るもの：
#   1. node_modules などビルド成果物（巨大・自動生成・各環境固有）
#   2. .secrets/ など秘密情報（個人鍵やトークン、絶対公開禁止）
#   3. .env など環境別設定
#   4. エディタ/OS が勝手に作るゴミファイル
#
# 新しい秘密情報を扱うことになったら、ここにパターンを追加してください。
# =====================================================================

# -----------------------------
# 依存パッケージ
# -----------------------------
node_modules/
.pnp.*
.yarn/cache/
.yarn/unplugged/
.yarn/build-state.yml
.yarn/install-state.gz

# -----------------------------
# 秘密情報（絶対にコミットしない）
# -----------------------------
# 環境変数ファイル
.env
.env.*
!.env.example

# Cloudflare Workers のローカル変数
.dev.vars
.dev.vars.*

# Firebase サービスアカウント鍵やその他の秘密ディレクトリ
.secrets/
secrets/

# 個別ファイル（万一のため広めにブロック）
*service-account*.json
*firebase-key*.json
*-private-key*.json
*.pem
*.key
!public-key.pem
id_rsa*

# -----------------------------
# Cloudflare Workers / Wrangler
# -----------------------------
.wrangler/
wrangler.toml.local
worker-configuration.d.ts.local

# -----------------------------
# ビルド出力
# -----------------------------
dist/
build/
out/
.next/
*.tsbuildinfo

# -----------------------------
# ログ・デバッグ
# -----------------------------
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# -----------------------------
# エディタ / IDE
# -----------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/
*.sublime-project
*.sublime-workspace

# -----------------------------
# OS
# -----------------------------
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
ehthumbs.db
desktop.ini
$RECYCLE.BIN/
*.lnk

# -----------------------------
# テスト・カバレッジ
# -----------------------------
coverage/
.nyc_output/
*.lcov

# -----------------------------
# バックアップ・一時ファイル
# -----------------------------
*.bak
*.backup
*.tmp
*.temp
*~

# -----------------------------
# このプロジェクト特有
# -----------------------------
# モック・PoC 段階の一時データ（必要に応じて整理）
mock/data.js

# Firestore ローカルエミュレータデータ
.firebase/
firebase-debug.log
firebase-debug.*.log
firestore-debug.log
ui-debug.log
